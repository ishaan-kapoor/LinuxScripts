#!/bin/sh

mute="$(pactl get-sink-mute @DEFAULT_SINK@  | awk '{print $2}')"
vol=$(pactl get-sink-volume @DEFAULT_SINK@ | head -1 | awk '{print ($12+$5)/2}')

[ "$vol" -gt 100 ] && notify-send "Volume too high"

if [ "$mute" = "yes" ]; then
  icon="ó°ťź"
else
